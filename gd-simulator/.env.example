# Supabase (optional — without these the app runs in local-only IndexedDB mode).
# Copy to .env.local and fill from Supabase → Settings → API.
# .env.local is gitignored; never commit real keys. The anon key is safe for the
# browser (RLS enforces access) but still keep it out of git.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
